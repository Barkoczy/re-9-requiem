{
  "UnderCO_c520s100_0000_ch0200": "<Sound Team ID>",
  "UnderCO_c520s100_0000_ch0100": "<Sound Team ID>",
  "UnderCO_c520s100_0000": "",
  "UnderCO_c520s100_0010_ch0100": "",
  "UnderCO_c520s100_0020_ch0200": "Leone. Jsi v pořádku?",
  "UnderCO_c520s100_0030_ch0100": "Jak dlouho jsem byl v bezvědomí?",
  "UnderCO_c520s100_0040_ch0200": "N-Nevím...",
  "UnderCO_c520s100_0050_ch0200": "D-Docela dlouho.",
  "UnderCO_c520s100_0060_ch0200": "Ty skvrny...",
  "UnderCO_c520s100_0070_ch0100": "Je to T-Virus.",
  "UnderCO_c520s100_0080_ch0100": "Třetí stádium infekce.",
  "UnderCO_c520s100_0090_ch0200": "K-Když jsi tak nemocný,",
  "UnderCO_c520s100_0100_ch0200": "proč jsi sem vůbec přišel?",
  "UnderCO_c520s100_0110_ch0100": "Tohle místo...",
  "UnderCO_c520s100_0120_ch0100": "Raccoon City je místo, kde to pro mě všechno začalo.",
  "UnderCO_c520s100_0130_ch0100": "Když se to všechno stalo, n-nemohl jsem—",
  "UnderCO_c520s100_0140_ch0100": "Nemohl jsem nic změnit.",
  "UnderCO_c520s100_0150_ch0100": "Tak jsem tady. Teď.",
  "UnderCO_c520s100_0160_ch0200": "Z-Zena nemůžeme zastavit.",
  "UnderCO_c520s100_0170_ch0100": "Říkal něco o tom, že znáš heslo.",
  "UnderCO_c520s100_0180_ch0100": "O čem to mluvil?",
  "UnderCO_c520s100_0190_ch0200": "N-Nevím!",
  "UnderCO_c520s100_0200_ch0200": "Promiň, já...",
  "UnderCO_c520s100_0210_ch0200": "Tady.",
  "UnderCO_c520s100_0220_ch0100": "Jdu zpátky.",
  "UnderCO_c520s100_0230_ch0100": "Zničím Elpis.",
  "UnderCO_c520s100_0240_ch0200": "P-Půjdu s tebou.",
  "UnderCO_c520s100_0250_ch0100": "Ne, nepůjdeš.",
  "UnderCO_c520s100_0260_ch0200": "Nechci už žádné výčitky!",
  "UnderCO_c520s100_0270_ch0200": "Ať to stojí cokoliv, počítej se mnou.",
  "UnderCO_c520s100_0280_ch0100": "Kdyby se mi něco stalo...",
  "UnderCO_c520s100_0290_ch0100": "Slib mi...",
  "UnderCO_c520s100_0295_ch0100": "že to ukončíš.",
  "UnderCO_c520s100_0300_ch0200": "Slibuju.",
  "UnderCO_0300_0000": "",
  "UnderCO_0300_0010_ch0100": "Pojď.",
  "UnderCO_0500_0000": "",
  "UnderCO_0500_0010_ch0200": "Podívej, támhle jsou dveře.",
  "UnderCO_0500_0020_ch0100": "Jenže je blokuje jeřáb.",
  "UnderCO_c520s200_0000_ch0200": "<Sound Team ID>",
  "UnderCO_c520s200_0000_ch0100": "<Sound Team ID>",
  "UnderCO_c520s200_0000": "",
  "UnderCO_c520s200_0010_ch0200": "Můžu se tam podívat za nás.",
  "UnderCO_c520s200_0020_ch0200": "Myslíš, že bys mě mohl vyhodit nahoru?",
  "UnderCO_c520s200_0030_ch0100": "To se asi brzy dozvíme.",
  "UnderCO_c520s200_0040_ch0100": "Pojď.",
  "UnderCO_c520s200_0050_ch0100": "Dávej tam na sebe pozor, jo?",
  "UnderCO_c520s200_0060_ch0200": "Budu.",
  "UnderCO_0600_0000": "",
  "UnderCO_0600_0010_ch0200": "Jakmile slezu dolů...už se zpátky nedostanu.",
  "UnderCO_0650_0000": "",
  "UnderCO_0650_0010_ch9916": "Systém uzamčen. Pro reaktivaci\r\nje vyžadován přepisovací klíč.",
  "UnderCO_0700_0000": "",
  "UnderCO_0700_0010_ch9916": "Varování: Úroveň hrozby \"oranžová\"\r\npotvrzena ve skladovacím sektoru.",
  "UnderCO_0700_0020_ch9916": "Kritická chyba: Selhání uzamčení ochranné zóny.",
  "UnderCO_0750_0000": "",
  "UnderCO_0750_0010_ch0200": "",
  "UnderCO_0800_0000": "",
  "UnderCO_0800_0010_ch0200": "",
  "UnderCO_0800_0020_dummy": "",
  "UnderCO_0800_0030_ch0200": "To... nevidí?",
  "UnderCO_0900_0000": "",
  "UnderCO_0900_0010_ch0200": "Kurva!",
  "UnderCO_1000_0000": "",
  "UnderCO_1000_0010_ch0200": "",
  "UnderCO_1100_0000": "",
  "UnderCO_1100_0010_ch0200": "",
  "UnderCO_1200_0000": "",
  "UnderCO_1200_0010_ch0200": "Našla jsem to.",
  "UnderCO_1210_0000": "",
  "UnderCO_1210_0010_ch0200": "",
  "UnderCO_1300_0000": "",
  "UnderCO_1300_0010_ch0200": "Dobře...ještě nejsem mrtvá.",
  "UnderCO_1400_0000": "",
  "UnderCO_1400_0010_ch0200": "",
  "UnderCO_1500_0000": "",
  "UnderCO_1500_0010_ch0200": "Tak, Leone. Buď opatrný.",
  "UnderCO_1520_0000": "",
  "UnderCO_1520_0010_ch0200": "Taky se musím pohnout.",
  "UnderCO_1600_0000": "",
  "UnderCO_1600_0010_ch0200": "Paráda.",
  "UnderCO_1700_0000": "",
  "UnderCO_1700_0020_ch9916": "Úroveň hrozby \"červená\" ve skladovacím sektoru.",
  "UnderCO_1700_0030_ch9916": "Restartování řídicího centra AI N0-AH.",
  "UnderCO_1700_0040_ch0200": "To ne.",
  "UnderCO_1750_0000": "",
  "UnderCO_1750_0010_ch0200": "OK, je to hned za tím.",
  "UnderCO_1900_0000": "",
  "UnderCO_1900_0010_ch0200": "To je ono. Zvládla jsem to.",
  "UnderCO_1950_0000": "",
  "UnderCO_1950_0010_ch9916": "Selhání restartu řídicího centra\r\nAI N0-AH: Žádná odezva.",
  "UnderCO_1950_0020_ch9916": "Ochranný protokol: Neaktivní",
  "UnderCO_1950_0030_ch9916": "Ochranný protokol: Neaktivní",
  "UnderCO_2010_0000": "",
  "UnderCO_2010_0010_ch0200": "",
  "UnderCO_2200_0000": "",
  "UnderCO_2200_0010_ch0200": "Ještě mám kus cesty.",
  "UnderCO_2200_0020_ch0200": "Jestlipak to Leon už zvládl.",
  "UnderCO_2400_0000": "",
  "UnderCO_2400_0010_ch0200": "Páni.",
  "UnderCO_c520s400_0000_ch0600": "<Sound Team ID>",
  "UnderCO_c520s400_0000_ch5400": "<Sound Team ID>",
  "UnderCO_c520s400_0000_ch0100": "<Sound Team ID>",
  "UnderCO_c520s400_0000_ch0200": "<Sound Team ID>",
  "UnderCO_c520s400_0000_ch1800": "<Sound Team ID>",
  "UnderCO_c520s400_0000": "",
  "UnderCO_c520s400_0010_ch0200": "Kde jsem to viděla...?",
  "UnderCO_c520s400_0020_ch1800": "Něco důležitého.",
  "UnderCO_c520s400_0030_ch1800": "Vysvětlím to později.",
  "UnderCO_c520s400_0040_ch1800": "Zavřít se do temné místnosti\r\ntakhle, to je na vás docela změna...",
  "UnderCO_c520s400_0060_ch1800": "po tom životě, který jste vedl.",
  "UnderCO_c520s400_0070_ch5400": "Život přináší nečekané zvraty, nemyslíte?",
  "UnderCO_c520s400_0080_ch1800": "Když se ohlédnete, máte pocit, že vaše\r\nrozhodnutí přispěla k...",
  "UnderCO_c520s400_0090_ch1800": "vaší současné situaci?",
  "UnderCO_c520s400_0100_ch5400": "Samozřejmě.",
  "UnderCO_c520s400_0110_ch5400": "Co zaseješ, to sklidíš.",
  "UnderCO_c520s400_0120_ch5400": "Není to přirozený řád věcí?",
  "UnderCO_c520s400_0130_ch1800": "Tak mi řekněte, lorde Spencere...",
  "UnderCO_c520s400_0140_ch1800": "co byste chtěl, aby svět věděl?",
  "UnderCO_c520s400_0150_ch5400": "Pravdu.",
  "UnderCO_c520s400_0160_ch5400": "Ale, ehm...",
  "UnderCO_c520s400_0170_ch5400": "krátká přestávka, než začneme, slečno Ashcroftová.",
  "UnderCO_c520s400_0180_ch5400": "Už nejsem mladík. Nemám tolik\r\nenergie jako dřív.",
  "UnderCO_c520s400_0190_ch0200": "Proč to máma schovávala?",
  "UnderCO_c520s400_0200_ch0100": "OK...",
  "UnderCO_c520s400_0210_ch0100": "Zase v akc—",
  "UnderCO_c520s400_0215_ch0100": "Do prdele.",
  "UnderCO_c520s400_0220_ch0600": "Jsi v pořádku, Leone?",
  "UnderCO_c520s400_0230_ch0100": "Teď jo.",
  "UnderCO_c520s400_0240_ch0100": "Grace mi uvolnila cestu.",
  "UnderCO_c520s400_0250_ch0600": "O tom nemluvím.",
  "UnderCO_c520s400_0260_ch0600": "Tvoje tělo už moc nevydrží.",
  "UnderCO_c520s400_0270_ch0100": "Vyřídím to.",
  "UnderCO_c520s400_0280_ch0100": "Ty jen pošli vrtulník\r\npro okamžitou evakuaci.",
  "UnderCO_2450_0000": "",
  "UnderCO_2450_0010_ch9916": "Narušení ochranné zóny. Zjištěn\r\nceloplošný výpadek sledování.",
  "UnderCO_2500_0000": "",
  "UnderCO_2500_0010_ch0100": "Támhle? Brnkačka.",
  "UnderCO_2550_0000": "",
  "UnderCO_2550_0010_ch9916": "Detekována bezpečnostní hrozba. Výtah\r\nodstaven. Vyžadována autorizace přepisovacím klíčem.",
  "UnderCO_2600_0000": "",
  "UnderCO_2600_0010_ch0100": "Tohle musí být ta místnost.",
  "UnderCO_2700_0000": "",
  "UnderCO_2700_0010_ch0100": "Sundám vás, kolik se dá, vy zmrdi.",
  "UnderCO_2800_0000": "",
  "UnderCO_2800_0010_ch0100": "Ach, do prdele. To snad ne...",
  "UnderCO_2900_0000": "",
  "UnderCO_2900_0010_ch0100": "Moc ses nezměnil, co?",
  "UnderCO_3000_0000": "",
  "UnderCO_3000_0010_ch0100": "",
  "UnderCO_3050_0000": "",
  "UnderCO_3050_0010_ch0100": "Jo jo... Pojďme to mít za sebou.",
  "UnderCO_3100_0000": "",
  "UnderCO_3100_0010_ch9916": "Varování: Autokláv kompromitován.\r\nUzamčení pouzdra nedostupné.",
  "UnderCO_3100_0020_ch9916": "Poškozená paměť. Funkce autoopravy offline.",
  "UnderCO_3110_0000": "",
  "UnderCO_3110_0010_ch9916": "Varování monitoru aerosolu.\r\nUzamčení pouzdra nedostupné.",
  "UnderCO_3300_0000": "",
  "UnderCO_3300_0010_ch9916": "Výtah zanedlouho dorazí.",
  "UnderCO_3400_0000": "",
  "UnderCO_3400_0010_ch9916": "Výtah dorazil.",
  "UnderCO_3500_0000": "",
  "UnderCO_3500_0010_ch0100": "Nemůžu tu ztrácet čas. Musím jít.",
  "UnderCO_3600_0000_ch0600": "<Sound Team ID>",
  "UnderCO_3600_0000_ch0100": "<Sound Team ID>",
  "UnderCO_3600_0000": "",
  "UnderCO_3600_0010_ch0100": "Už jsem skoro tam, Sherry.",
  "UnderCO_3600_0020_ch0600": "...Leone...",
  "UnderCO_3600_0030_ch0100": "Kurva...",
  "UnderCO_3660_0000": "",
  "UnderCO_3660_0010_ch0100": "Ještě to neskončilo...",
  "UnderCO_3660_0020_ch0100": "",
  "UnderCO_c520s700_0000_ch0200": "<Sound Team ID>",
  "UnderCO_c520s700_0000_ch5400": "<Sound Team ID>",
  "UnderCO_c520s700_0000_ch1800": "<Sound Team ID>",
  "UnderCO_c520s700_0000": "",
  "UnderCO_c520s700_0020_ch1800": "Jaký odkaz chcete\r\npo sobě zanechat?",
  "UnderCO_c520s700_0030_ch5400": "Můj výzkum otevřel Pandořinu skříňku,",
  "UnderCO_c520s700_0040_ch5400": "a uvolnil pohromu na svět.",
  "UnderCO_c520s700_0050_ch1800": "Až na Elpis...bohyni naděje?",
  "UnderCO_c520s700_0060_ch1800": "Aspoň tak to říká mýtus.",
  "UnderCO_c520s700_0070_ch5400": "Slepá naděje.",
  "UnderCO_c520s700_0080_ch1800": "Jak to myslíte?",
  "UnderCO_c520s700_0090_ch5400": "Lidé nedokážou předvídat,\r\nkdy si pro ně přijde smrt.",
  "UnderCO_c520s700_0100_ch5400": "Proto mají naději.",
  "UnderCO_c520s700_0110_ch5400": "Mýlil jsem se...",
  "UnderCO_c520s700_0120_ch5400": "a sžírá mě vina.",
  "UnderCO_c520s700_0130_ch5400": "Štěstí nelze dosáhnout\r\nna úkor druhých.",
  "UnderCO_c520s700_0140_ch5400": "Myslím, že to pro dnešek stačí.",
  "UnderCO_c520s700_0150_ch1800": "Proč jste přijal mou\r\nžádost o rozhovor?",
  "UnderCO_c520s700_0160_ch5400": "",
  "UnderCO_c520s700_0170_ch1800": "Kdo je t—?",
  "UnderCO_c520s700_0180_ch1800": "Je to jeden z vašich subjektů?",
  "UnderCO_c520s700_0190_ch5400": "Samozřejmě, že ne.",
  "UnderCO_c520s700_0200_ch5400": "Byla na světě sama.",
  "UnderCO_c520s700_0210_ch5400": "Vzal jsem si ji, abych odčinil své hříchy.",
  "UnderCO_c520s700_0220_ch5400": "Je...?",
  "UnderCO_c520s700_0230_ch5400": "Naprosto normální.",
  "UnderCO_c520s700_0240_ch5400": "Obyčejné dítě, které potřebovalo domov.",
  "UnderCO_c520s700_0250_ch5400": "Ona...",
  "UnderCO_c520s700_0260_ch5400": "je mou nadějí.",
  "UnderCO_c520s700_0270_ch5400": "Že jsi krásná?",
  "UnderCO_c520s700_0280_ch5400": "Chcete si ji pochovat?",
  "UnderCO_c520s700_0290_ch1800": "Ó! Ehm...",
  "UnderCO_c520s700_0295_ch1800": "Dobře.",
  "UnderCO_c520s700_0300_ch1800": "Je roztomilá.",
  "UnderCO_c520s700_0310_ch1800": "Jak se jmenuje?",
  "UnderCO_c520s700_0320_ch5400": "Grace.",
  "UnderCO_c520s700_0330_ch1800": "Grace.",
  "UnderCO_c520s700_0340_ch1800": "Chcete mi ještě něco sdělit?",
  "UnderCO_c520s700_0350_ch5400": "Řekl jsem, co jsem chtěl.",
  "UnderCO_c520s700_0360_ch5400": "Jen doufám, že to poslouží jako rekviem\r\nza ty, kteří odešli.",
  "UnderCO_c520s700_0370_ch0200": "Leone?",
  "UnderCO_c520s700_0380_ch0200": "Leone!",
  "UnderCO_3700_0000": "",
  "UnderCO_3700_0010_ch0200": "Musím si pospíšit.",
  "UnderCO_3800_0000": "",
  "UnderCO_3800_0010_ch0200": "Konečně mám šanci něco udělat.",
  "UnderCO_3900_0000": "",
  "UnderCO_3900_0010_ch0200": "Leone!",
  "UnderCO_c520s920_0000_ch8000": "<Sound Team ID>",
  "UnderCO_c520s920_0000_ch0200": "<Sound Team ID>",
  "UnderCO_c520s920_0000_ch0100": "<Sound Team ID>",
  "UnderCO_c520s920_0000": "",
  "UnderCO_c520s920_0010_ch0200": "Leone!",
  "UnderCO_c520s920_0015_ch0200": "To ne.",
  "UnderCO_c520s920_0020_ch0200": "Hej! To jsem já, Grace.",
  "UnderCO_c520s920_0025_ch0200": "Prosím, probuď se.",
  "UnderCO_c520s920_0030_ch0200": "No tak. Vzbuď se, vzbuď se.",
  "UnderCO_c520s920_0040_ch0200": "Hej! Hej.",
  "UnderCO_c520s920_0045_ch0100": "Čau.",
  "UnderCO_c520s920_0050_ch0100": "Jen jsem si přivřel oči.",
  "UnderCO_c520s920_0060_ch0200": "Jsi v pořádku.",
  "UnderCO_c520s920_0070_ch0200": "Pomůžu ti.",
  "UnderCO_c520s920_0080_ch0100": "Do toho.",
  "UnderCO_c520s920_0090_ch0200": "OK.",
  "UnderCO_c520s920_0100_ch0200": "N-Neznám to heslo.",
  "UnderCO_c520s920_0110_ch0100": "To je v pohodě, Zeno nám to nechal dokořán.",
  "UnderCO_c520s920_0120_ch0100": "Stačí zadat jakýkoliv špatný kód.\r\nTo zničí Elpis.",
  "UnderCO_c520s920_0130_ch0200": "Tak to zkusíme.",
  "UnderCO_c520s920_0140_ch0100": "Grace, ať to stojí cokoliv...",
  "UnderCO_c520s920_0150_ch0100": "Získám ti čas.",
  "UnderCO_c520s920_0160_ch0200": "Ne. Ne, ne, mám nápad.",
  "UnderCO_c520s920_0170_ch0100": "Věřím ti. Věřím ti.",
  "UnderCO_c520s920_0180_ch8000": "Tak, marnotratná dcera se vrací.",
  "UnderCO_c520s920_0190_ch0200": "Znám to heslo.",
  "UnderCO_c520s920_0200_ch8000": "Naplň svůj osud a vše bude odpuštěno.",
  "UnderCO_c520s920_0210_ch0200": "J-Jenom pokud necháš Leona žít.",
  "UnderCO_c520s920_0220_ch8000": "Budiž.",
  "UnderCO_5015_0000_ch9945": "サウンド用ID",
  "UnderCO_5015_0000": "",
  "UnderCO_5015_0010_ch9945": "Věz, že jsi mou nadějí.",
  "UnderCO_5015_0020_ch9945": "Ona je mou nadějí.",
  "UnderCO_5015_0030_ch9945": "Slepá naděje.",
  "UnderCO_5020_0000": "",
  "UnderCO_5020_0010_ch0200": "OK...",
  "UnderCO_5100_0000": "",
  "UnderCO_5100_0010_ch0200": "",
  "UnderCO_5150_0000_ch9945": "サウンド用ID",
  "UnderCO_5150_0000": "",
  "UnderCO_5150_0010_ch9945": "Mýlil jsem se a sžírá mě vina.",
  "UnderCO_5150_0020_ch9945": "Zničím Elpis.",
  "UnderCO_5150_0030_ch9945": "Slib mi...že to ukončíš.",
  "UnderCO_5200_0000": "",
  "UnderCO_5200_0010_ch0200": "To je ono.",
  "UnderCO_5300_0000": "",
  "UnderCO_5300_0010_ch0200": "Počkat...je to opravdu tohle?"
}
