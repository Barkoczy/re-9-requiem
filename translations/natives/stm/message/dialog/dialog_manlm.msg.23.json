  "ManLM_c322s000_0000": "",
  "ManLM_c322s000_0010_ch5100": "Proč jsi tady?",
  "ManLM_c322s000_0015_ch5100": "Je to kvůli mně?",
  "ManLM_c322s000_0020_ch5100": "Nebo kvůli ní?",
  "ManLM_c322s000_0030_ch5100": "Můžeme si promluvit.",
  "ManLM_c322s000_0040_ch5100": "Správně.",
  "ManLM_c322s000_0050_ch5100": "Nebo můžeme zahájit tvoji \\\"léčbu.\\\"",
  "ManLM_c322s000_0060_ch0100": "Doufám, že léčbu mlčením.",
  "ManLM_c322s000_0070_ch5100": "Jsi vyšetřovatel, ne?",
  "ManLM_c322s000_0080_ch5100": "Tak vyšetřuj.",
  "ManLM_c322s000_0090_ch5100": "Co chceš vědět?",
  "ManLM_c322s000_0100_ch5100": "Je tohle místo, kde provádím svůj výzkum?",
  "ManLM_c322s000_0110_ch5100": "Ano.",
  "ManLM_c322s000_0120_ch5100": "Jsou odpovědi na tvoji nemoc tady?",
  "ManLM_c322s000_0130_ch5100": "...Ano.",
  "ManLM_c322s000_0140_ch0100": "Víš, mám jednu otázku.",
  "ManLM_c322s000_0150_ch0100": "Kdy sis naposledy čistil\r\nzuby?",
  "ManLM_c322s000_0160_ch5100": "Ty...",
  "ManLM_c322s000_0170_ch5100": "jsi ignorantský...hlupák.",
  "ManLM_c322s000_0180_ch5100": "Věříš v lidskou evoluci?",
  "ManLM_c322s000_0190_ch5100": "Zasvětil jsem svůj život jejímu studiu.",
  "ManLM_c322s000_0200_ch5100": "Zatímco ty jsi zasvětil svůj život...",
  "ManLM_c322s000_0210_ch5100": "neúspěchu.",
  "ManLM_c322s000_0220_ch5100": "Jsi mrtvý muž!",
  "ManLM_c322s000_0230_ch0100": "Hej, slyšíš mě?",
  "ManLM_c322s000_0240_ch0600": "Leone? Snažila jsem se ti dovolat.",
  "ManLM_c322s000_0250_ch0100": "Promiň, byl jsem trochu svázaný.",
  "ManLM_c322s000_0260_ch0100": "Dostala jsi, o co jsem prosil?",
  "ManLM_c322s000_0270_ch0600": "Plán budovy? Jo, posílám.",
  "ManLM_c322s000_0280_ch0100": "Mluvil jsem s Victorem.",
  "ManLM_c322s000_0290_ch0100": "Je úplně šílený.",
  "ManLM_c322s000_0300_ch0100": "Zamířím do jeho kanceláře.",
  "ManLM_0100_0000": "",
  "ManLM_0100_0010_ch0100": "Rád, že ta agentka FBI utekla.",
  "ManLM_0100_0020_ch0600": "FBI?",
