{
  "ManGW_c351s000_0000_ch1300": "<Sound Team ID>",
  "ManGW_c351s000_0000_ch0200": "<Sound Team ID>",
  "ManGW_c351s000_0000": "",
  "ManGW_c351s000_0010_ch0200": "Dostanu tě ven, Emily.",
  "ManGW_c351s000_0020_ch1300": "",
  "ManGW_0010_0000": "",
  "ManGW_0010_0010_ch0200": "Musí existovat cesta\r\nna povrch.",
  "ManGW_0020_0000": "",
  "ManGW_0020_0010_ch1300": "Ngh...",
  "ManGW_0030_0000": "",
  "ManGW_0030_0010_ch0200": "Omlouvám se. Vím, že to bolí.",
  "ManGW_0030_0020_ch0200": "Moc se omlouvám.",
  "ManGW_c351s200_0000_ch1300": "<Sound Team ID>",
  "ManGW_c351s200_0000_ch0200": "<Sound Team ID>",
  "ManGW_c351s200_0000": "",
  "ManGW_c351s200_0010_ch0200": "Slepá ulička...",
  "ManGW_c351s200_0020_ch0200": "Nemůžu dovolit, aby jí to ublížilo.",
  "ManGW_c351s200_0030_ch0200": "Bude to dobré, Emily.",
  "ManGW_c351s200_0040_ch0200": "Tady. Odpočívej tady.",
  "ManGW_c351s200_0050_ch0200": "Tady máš.",
  "ManGW_c351s200_0060_ch0200": "Musím tě udržet v bezpečí.",
  "ManGW_c351s200_0070_ch1300": "OK.",
  "ManGW_0040_0000": "",
  "ManGW_0040_0010_ch0200": "Musí existovat způsob, jak tu věc zabít.",
  "ManGW_0067_0000": "",
  "ManGW_0067_0010_ch9914": "Nedostatečný výkon. Resetujte napájecí\r\njednotky na nižším patře.",
  "ManGW_0070_0000": "",
  "ManGW_0070_0010_ch0200": "Musím zapnout elektřinu.\r\nJe to moje jediná šance.",
  "ManGW_0075_0000": "",
  "ManGW_0075_0010_ch0200": "Musím najít ty napájecí jednotky.",
  "ManGW_0080_0000": "",
  "ManGW_0080_0010_ch0200": "Ještě dvě.",
  "ManGW_0090_0000": "",
  "ManGW_0090_0010_ch0200": "Ještě jedna.",
  "ManGW_0100_0000": "",
  "ManGW_0100_0010_ch0200": "Tím by se měl otevřít poklop.\r\nMusím si pospíšit.",
  "ManGW_0105_0000": "",
  "ManGW_0105_0010_ch9914": "Napájení bylo úspěšně obnoveno.",
  "ManGW_0130_0000": "",
  "ManGW_0130_0010_ch0200": "Odsud odcházíme.\r\nUhněte z kurva cesty!",
  "ManGW_0140_0000": "",
  "ManGW_0140_0010_ch0200": "No tak! Otevři se!",
  "ManGW_0145_0000": "",
  "ManGW_0145_0010_ch0200": "Ugh, konečně...",
  "ManGW_0150_0000": "",
  "ManGW_0150_0010_ch0200": "Emily, prosím buď v pořádku.",
  "ManGW_0160_0000": "",
  "ManGW_0160_0010_ch0200": "Ne! Ne, ne, ne, ne, ne, ne, ne!\r\nTo je Emily! To je Emily!",
  "ManGW_0161_0000": "",
  "ManGW_0161_0010_ch0200": "Ne, prosím přestaňte! Prosím!\r\nProsím přestaňte, prosím!",
  "ManGW_0163_0000": "",
  "ManGW_0163_0010_ch0200": "Prosím poslouchej mě! Leone, poslouchej!",
  "ManGW_0164_0000": "",
  "ManGW_0164_0010_ch0200": "Posloucháš? Říkala jsem přestaň!\r\nTo je—to je Emily!",
  "ManGW_0170_0000": "",
  "ManGW_0170_0010_ch0200": "Zůstaň zpátky!",
  "ManGW_0171_0000": "",
  "ManGW_0171_0010_ch0200": "Dej mi pokoj.",
  "ManGW_0173_0000": "",
  "ManGW_0173_0010_ch0200": "Tak už chcípni!",
  "ManGW_0174_0000": "",
  "ManGW_0174_0010_ch0200": "Zabralo to.",
  "ManGW_0175_0000": "",
  "ManGW_0175_0010_ch0200": "To bylo o fous.",
  "ManGW_0180_0000": "",
  "ManGW_0180_0010_ch0200": "Proč to nepřestane!?",
  "ManGW_0190_0000": "",
  "ManGW_0190_0010_ch0200": "Kde jsou ty napájecí jednotky?",
  "ManGW_0191_0000": "",
  "ManGW_0191_0010_ch0200": "Kde je ta napájecí jednotka?",
  "ManGW_0195_0000": "",
  "ManGW_0195_0010_ch0200": "Co to kurva!?",
  "ManGW_0200_0000": "",
  "ManGW_0200_0010_ch0200": "Žádná páka...",
  "ManGW_0200_0020_ch0200": "Někde tu musí být.",
  "ManGW_0210_0000": "",
  "ManGW_0210_0010_ch0200": "Proč...je...tak tuhá?",
  "ManGW_0220_0000_ch0200": "<Sound Team ID>",
  "ManGW_0220_0000": "",
  "ManGW_0220_0010_ch0200": "",
  "ManGW_0500_0000_ch0200": "<Sound Team ID>",
  "ManGW_0500_0000": "",
  "ManGW_0500_0010_ch0200": "",
  "ManGW_0600_0000": "",
  "ManGW_0600_0010_ch0200": "",
  "ManGW_0610_0000": "",
  "ManGW_0610_0010_ch0200": "",
  "ManGW_0620_0000": "",
  "ManGW_0620_0010_ch0200": "",
  "ManGW_0630_0000": "",
  "ManGW_0630_0010_ch0200": "",
  "ManGW_0640_0000": "",
  "ManGW_0640_0010_ch0200": "",
  "ManGW_c351s800_0000_ch0200": "<Sound Team ID>",
  "ManGW_c351s800_0000_ch0100": "<Sound Team ID>",
  "ManGW_c351s800_0000": "",
  "ManGW_c351s800_0010_ch0200": "",
  "ManGW_c351s800_0020_ch0200": "Emily, to jsem já!",
  "ManGW_c351s800_0030_ch0200": "Emily?",
  "ManGW_c351s800_0040_ch0200": "Ó ne. Ó ne. Ó ne!",
  "ManGW_c351s800_0050_ch0200": "Probuď se! No tak!",
  "ManGW_c351s800_0060_ch0200": "Ó do prdele.",
  "ManGW_c351s800_0070_ch0200": "Ó ne.",
  "ManGW_c351s800_0080_ch0200": "Emily!",
  "ManGW_c351s800_0090_ch0200": "No tak, Emily.",
  "ManGW_c351s800_0100_ch0200": "Probuď se, Emily!",
  "ManGW_c351s800_0110_ch0200": "No tak!",
  "ManGW_c351s800_0120_ch0200": "No tak!",
  "ManGW_c351s800_0130_ch0200": "Emily!",
  "ManGW_c351s800_0140_ch0200": "Selhala jsem.",
  "ManGW_c351s800_0150_ch0200": "Emily!? Ahoj, to jsem já.\r\nJ-Jsem tady.",
  "ManGW_c351s800_0160_ch0200": "Jsi v pořádku. Jsi v pořádku.",
  "ManGW_c351s800_0170_ch0200": "E-Emily!?",
  "ManGW_c351s800_0180_ch0200": "Emily!",
  "ManGW_c351s800_0190_ch0200": "Emily?",
  "ManGW_c351s800_0200_ch0200": "Ne! Ne, ne, ne, ne, ne, ne, ne!",
  "ManGW_c351s800_0210_ch0200": "To je Emily! To je Emily!",
  "ManGW_c351s800_0220_ch0100": "Je mi to líto.",
  "ManGW_c351s910_0000_ch8000": "<Sound Team ID>",
  "ManGW_c351s910_0000_ch0200": "<Sound Team ID>",
  "ManGW_c351s910_0000_ch5100": "<Sound Team ID>",
  "ManGW_c351s910_0000_ch0100": "<Sound Team ID>",
  "ManGW_c351s910_0000": "",
  "ManGW_c351s910_0005_ch0200": "Ne!",
  "ManGW_c351s910_0010_ch0200": "Ne, ne, ne, ne, ne!",
  "ManGW_c351s910_0020_ch0200": "Ne, ne, ne, ne, ne—Emily!",
  "ManGW_c351s910_0030_ch0200": "Chtěla jsem ji zachránit!",
  "ManGW_c351s910_0040_ch0100": "Nechápeš, to je proto—",
  "ManGW_c351s910_0050_ch0200": "Ne! Bez ní bych nikdy neutekla.",
  "ManGW_c351s910_0060_ch0200": "Tohle je všechno moje vina. Zase!",
  "ManGW_c351s910_0070_ch0100": "Hele, chápu to. Věř mi, chápu to.",
  "ManGW_c351s910_0080_ch0100": "Ale jsme pořád naživu.\r\nMusíme jít dál.",
  "ManGW_c351s910_0090_ch0200": "Ne.",
  "ManGW_c351s910_0100_ch0100": "Grace...",
  "ManGW_c351s910_0110_ch5100": "Elpis je na dosah, Grace.",
  "ManGW_c351s910_0120_ch5100": "Rád bych, abys šla se mnou.",
  "ManGW_c351s910_0130_ch0200": "Šla s tebou?",
  "ManGW_c351s910_0140_ch5100": "Ó, cítíš se ztracená, ale nejsi.",
  "ManGW_c351s910_0150_ch5100": "Jsi přesně tam, kde máš být.",
  "ManGW_c351s910_0160_ch8000": "Čekal jsem na tebe, Grace.",
  "ManGW_c351s910_0170_ch0200": "Kdo jsi?",
  "ManGW_c351s910_0180_ch8000": "Raccoon City...",
  "ManGW_c351s910_0190_ch8000": "Jsi příčinou jeho zničení.",
  "ManGW_c351s910_0200_ch8000": "Ale jsi i klíčem k vybudování\r\nstatečného nového světa.",
  "ManGW_c351s910_0210_ch8000": "Jsi poslední dílek.",
  "ManGW_c351s910_0220_ch8000": "Dovol nám ukázat ti tvůj pravý účel.",
  "ManGW_c351s210_0000_ch1300": "<Sound Team ID>",
  "ManGW_c351s210_0000_ch0200": "<Sound Team ID>",
