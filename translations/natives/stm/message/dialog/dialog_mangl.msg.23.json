  "ManGL_3014_0010_ch4000": "Přestaňteee!",
  "ManGL_3015_0000": "",
  "ManGL_3015_0010_ch4000": "Chci domů!",
  "ManGL_3016_0000": "",
  "ManGL_3016_0010_ch4000": "Chci domů!",
  "ManGL_3022_0000": "",
  "ManGL_3022_0010_ch4000": "Pusťte mě veeen!",
