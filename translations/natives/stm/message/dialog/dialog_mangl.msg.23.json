{
  "ManGL_1010_0000": "",
  "ManGL_1010_0010_ch0200": "Co to kurva?",
  "ManGL_1030_0000": "",
  "ManGL_1030_0010_ch0200": "Našla jsem tě.",
  "ManGL_c341s400_0000_ch5100": "<Sound Team ID>",
  "ManGL_c341s400_0000_ch0200": "<Sound Team ID>",
  "ManGL_c341s400_0000_ch9912": "<Sound Team ID>",
  "ManGL_c341s400_0000": "",
  "ManGL_c341s400_0010_ch5100": "Ano, Zeno, přesně tak.",
  "ManGL_c341s400_0020_ch5100": "Všechny testy vyšly pozitivně.\r\nMohu potvrdit, že je skutečně...",
  "ManGL_c341s400_0030_ch5100": "ta, kterou jsme hledali.",
  "ManGL_c341s400_0040_ch5100": "Pokud vše půjde podle plánu, Elpis bude\r\nbrzy v našich rukou.",
  "ManGL_c341s400_0050_ch5100": "Samozřejmě.",
  "ManGL_c341s400_0060_ch5100": "Ale nejdřív musím zahájit protokol.",
  "ManGL_c341s400_0070_ch5100": "Dokázal jsem to.",
  "ManGL_c341s400_0080_ch5100": "Dokázal jsem to.",
  "ManGL_c341s400_0090_ch5100": "Dokázal jsem to!",
  "ManGL_c341s400_0100_ch0200": "Ó ne.",
  "ManGL_c341s400_0110_ch9912": "Byl zahájen protokol sebezničení.",
  "ManGL_c341s400_0120_ch9912": "Veškerý personál, prosím evakuujte.",
  "ManGL_c341s400_0130_ch9912": "Opakuji, byl zahájen protokol\r\nsebezničení.",
  "ManGL_c341s400_0140_ch0200": "Ó, do prdele.",
  "ManGL_c341s400_0150_ch9912": "Veškerý personál, prosím evakuujte.",
  "ManGL_1040_0000": "",
  "ManGL_1040_0010_ch0200": "Kde je ta místnost!? Co to sakra!?",
  "ManGL_1041_0000": "",
  "ManGL_1041_0010_ch0200": "",
  "ManGL_1042_0000": "",
  "ManGL_1042_0010_ch0200": "Do prdele, OK.",
  "ManGL_1043_0000": "",
  "ManGL_1043_0010_ch0200": "Sakra!",
  "ManGL_1044_0000": "",
  "ManGL_1044_0010_ch0200": "Prosím, funguj!",
  "ManGL_1045_0000": "",
  "ManGL_1045_0010_ch0200": "O-OK.",
  "ManGL_1048_0000": "",
  "ManGL_1048_0010_ch0200": "Do prdele, do prdele, do prdele!",
  "ManGL_1050_0000": "",
  "ManGL_1050_0010_ch0200": "",
  "ManGL_1050_0020_ch0200": "Kurva! Ó můj bože...",
  "ManGL_1055_0000": "",
  "ManGL_1055_0010_ch0200": "",
  "ManGL_1060_0000": "",
  "ManGL_1060_0010_ch0200": "Pomoc! Pomoc!",
  "ManGL_1065_0000": "",
  "ManGL_1065_0010_ch0200": "Zvládla jsem to!",
  "ManGL_1065_0020_ch0200": "OK...už jdu, Emily.",
  "ManGL_1068_0000": "",
  "ManGL_1068_0010_ch0200": "Musím se dostat k helikoptéře.",
  "ManGL_1070_0000": "",
  "ManGL_1070_0020_ch0200": "Proč se to kurva pořád děje!?",
  "ManGL_9991_0000": "",
  "ManGL_9991_0010_ch9912": "Byl zahájen protokol sebezničení.\r\nVeškerý personál, prosím evakuujte.",
  "ManGL_9991_0020_ch9912": "Opakuji, veškerý personál, prosím evakuujte.",
  "ManGL_9992_0000": "",
  "ManGL_9992_0010_ch9912": "Byl zahájen protokol sebezničení.\r\nOdemykání likvidačních nádrží.",
  "ManGL_9992_0020_ch9912": "Veškerý personál, zlikvidujte vzorky\r\na okamžitě evakuujte.",
  "ManGL_c341s900_0000_ch0200": "<Sound Team ID>",
  "ManGL_c341s900_0000_ch1510": "<Sound Team ID>",
  "ManGL_c341s900_0000_ch1300": "<Sound Team ID>",
  "ManGL_c341s900_0000": "",
  "ManGL_c341s900_0010_ch1510": "Máš to!?",
  "ManGL_c341s900_0020_ch0200": "Jo!",
  "ManGL_c341s900_0025_ch1510": "Dobře.",
  "ManGL_c341s900_0030_ch0200": "Ó můj bože.",
  "ManGL_c341s900_0040_ch1510": "",
  "ManGL_c341s900_0050_ch1510": "Co jsi to kurva udělala?",
  "ManGL_c341s900_0060_ch1300": "Grace?",
  "ManGL_c341s900_0070_ch1300": "Grace, co se děje?",
  "ManGL_c341s900_0080_ch0200": "Bude to dobré, Emily. Jsem tady.",
  "ManGL_c341s900_0090_ch0200": "Emily? Bude to trochu hrbolatý.",
  "ManGL_c341s900_0100_ch0200": "Jsem hned vedle tebe.",
  "ManGL_c341s900_0110_ch1510": "Ne, holka. Budu tě potřebovat vepředu.",
  "ManGL_c341s900_0120_ch1300": "Je to OK, jsem v pořádku.",
  "ManGL_c341s900_0125_ch0200": "OK.",
  "ManGL_c341s900_0130_ch1510": "No tak, no tak, no tak.",
  "ManGL_c341s900_0140_ch0200": "Ó, je jich tolik!",
  "ManGL_c341s900_0150_ch1510": "Připoutej se!",
  "ManGL_c341s900_0155_ch1510": "",
  "ManGL_c341s900_0160_ch0200": "No tak!",
  "ManGL_c341s900_0170_ch1510": "A co si myslíš, že dělám!?",
  "ManGL_c341s900_0180_ch0200": "Rychle! Rychle!",
  "ManGL_c341s900_0190_ch1510": "Fakt!?",
  "ManGL_c341s900_0200_ch1510": "Držte se, vzlétám!",
  "ManGL_c341s900_0210_ch1510": "Slez ze mě!",
  "ManGL_c341s900_0220_ch1510": "Vypadni kurva ze mě!",
  "ManGL_c341s900_0230_ch1510": "Ty parchante!",
  "ManGL_c341s900_0240_ch1510": "Vypadni kurva—",
  "ManGL_c341s900_0250_ch0200": "Emily, jsi v pořádku!?",
  "ManGL_c341s900_0260_ch0200": "Emily...",
  "ManGL_3003_0000": "",
  "ManGL_3003_0010_ch4000": "Nechci...umřííít!",
  "ManGL_3004_0000": "",
  "ManGL_3004_0010_ch4000": "Nechci umřííít!",
  "ManGL_3005_0000": "",
  "ManGL_3005_0010_ch4000": "Nechci umřííít!",
  "ManGL_3006_0000": "",
  "ManGL_3006_0010_ch4000": "P-Pooomoooc...mi!",
  "ManGL_3007_0000": "",
  "ManGL_3007_0010_ch4000": "Pomozte miiii!",
  "ManGL_3008_0000": "",
  "ManGL_3008_0010_ch4000": "Pomozte miii!",
  "ManGL_3009_0000": "",
  "ManGL_3009_0010_ch4000": "Pusťte mě veeen!",
  "ManGL_3010_0000": "",
  "ManGL_3010_0010_ch4000": "Pusťte mě veeen!",
  "ManGL_3012_0000": "",
