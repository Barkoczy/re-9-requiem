  "Hotel3_0465_0010_ch0200": "",
  "Hotel3_c111s220_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s220_0000": "",
  "Hotel3_c111s220_0010_ch0200": "K-Kdo je tam!?",
  "Hotel3_c111s220_0020_ch0200": "Ježíši.",
  "Hotel3_c111s220_0030_ch0200": "C-Co mám dělat?",
  "Hotel3_0520_0000": "",
  "Hotel3_0520_0010_ch0200": "",
  "Hotel3_0580_0000": "",
  "Hotel3_0580_0010_ch0200": "",
  "Hotel3_0610_0000": "",
  "Hotel3_0610_0010_ch9906": "Tělo muže...Elbridge tohle...",
  "Hotel3_0610_0020_ch9906": "Policie...řada záhadných úmrtí...",
  "Hotel3_0650_0000": "",
  "Hotel3_0650_0010_ch0200": "Kurva...",
  "Hotel3_0850_0000": "",
  "Hotel3_0850_0010_ch0200": "Cože? Kdo...?",
