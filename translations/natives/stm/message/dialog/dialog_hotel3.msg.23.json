  "Hotel3_c111s210_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s210_0000": "",
  "Hotel3_c111s210_0010_ch0200": "Nemůžu...",
  "Hotel3_c111s210_0020_ch0200": "Je toho moc.",
  "Hotel3_c111s210_0030_ch0200": "Tak dělej, Grace.",
