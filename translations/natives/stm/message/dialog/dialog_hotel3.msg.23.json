  "Hotel3_c111s900_0000_ch5100": "<Sound Team ID>",
  "Hotel3_c111s900_0000_ch4030": "<Sound Team ID>",
  "Hotel3_c111s900_0000": "",
  "Hotel3_c111s900_0010_ch0200": "",
  "Hotel3_c111s900_0020_ch0200": "Co to...?",
  "Hotel3_c111s900_0030_ch0200": "J-Je...",
  "Hotel3_c111s900_0040_ch0200": "Je tam někdo?",
  "Hotel3_c111s900_0050_ch0200": "H-Haló?",
  "Hotel3_c111s900_0060_ch5100": "Nebylo to snadné.",
  "Hotel3_c111s900_0070_ch5100": "Ale po velkém úsilí jsme konečně tady.",
  "Hotel3_c111s900_0080_ch0200": "Kdo jste?",
  "Hotel3_c111s900_0090_ch5100": "Jsem ten, kdo tam nechal to tělo.",
  "Hotel3_c111s900_0100_ch5100": "Jsem ten, kdo vás sem přivedl.",
  "Hotel3_c111s900_0110_ch5100": "Teď vím, že jste ta,\nkterou jsem hledal.",
  "Hotel3_c111s900_0120_ch5100": "Ta výjimečná. Ta vyvolená.",
  "Hotel3_c111s900_0130_ch5100": "Slečno Ashcroft.",
  "Hotel3_c111s900_0140_ch5100": "Šššš...",
  "Hotel3_c111s900_0150_ch5100": "Odpočívejte, Grace.",
  "Hotel3_c111s900_0160_ch5100": "Čeká nás toho tolik.",
  "Hotel3_9000_0000": "",
  "Hotel3_9000_0010_ch2000": "Ano, vím.",
  "Hotel3_9001_0000": "",
  "Hotel3_9001_0010_ch2000": "Aha.",
  "Hotel3_9002_0000": "",
  "Hotel3_9002_0010_ch2000": "Ne, ne, to je v pohodě.",
  "Hotel3_9003_0000": "",
  "Hotel3_9003_0010_ch2000": "Jo, rozumím.",
  "Hotel3_9004_0000": "",
  "Hotel3_9004_0010_ch2000": "Ach, to vůbec nevadí.",
  "Hotel3_9005_0000": "",
  "Hotel3_9005_0010_ch2000": "Jo...aha. Jasně.",
  "Hotel3_9006_0000": "",
  "Hotel3_9006_0010_ch2000": "Ano. Hned se do toho pustím.",
  "Hotel3_9010_0000": "",
  "Hotel3_9010_0010_ch2000": "Co je?",
  "Hotel3_9011_0000": "",
  "Hotel3_9011_0010_ch2000": "Jo, to vím.",
  "Hotel3_9012_0000": "",
  "Hotel3_9012_0010_ch2000": "[tch]",
  "Hotel3_9013_0000": "",
  "Hotel3_9013_0010_ch2000": "Haló?",
  "Hotel3_9014_0000": "",
  "Hotel3_9014_0010_ch2000": "Dej mi pokoj.",
  "Hotel3_9015_0000": "",
  "Hotel3_9015_0010_ch2000": "Vypadám, že mě to zajímá?",
  "Hotel3_9016_0000": "",
  "Hotel3_9016_0010_ch2000": "Jo, přesně tak.",
  "Hotel3_9017_0000": "",
  "Hotel3_9017_0010_ch2000": "Potřebuju, abys to zařídil.",
  "Hotel3_9030_0000": "",
  "Hotel3_9030_0010_ch2000": "Tak co? Jak to dopadlo s manželkou?",
  "Hotel3_9030_0020_ch2000": "Bože, ta byla naštvaná. Ale nakonec mi odpustila.",
  "Hotel3_9030_0030_ch2000": "Ještě jsi z toho vyváznul. Už žádnou takovou\nblbost neuděláš, co?",
  "Hotel3_9030_0040_ch2000": "V žádném případě. Přísahám, už nikdy.",
  "Hotel3_9030_0050_ch2000": "A co ty?",
  "Hotel3_9030_0060_ch2000": "Pořád stejný. Nemůžu si stěžovat.",
  "Hotel3_9030_0070_ch2000": "Tím myslíš, že jsi nuda.",
  "Hotel3_9030_0080_ch2000": "Za to, že jsi samý drama, já nemůžu.",
  "Hotel3_9040_0000": "",
  "Hotel3_9040_0010_ch2000": "Promiň, jdu pozdě!",
  "Hotel3_9040_0020_ch2100": "To je v pohodě. Sám jsem tu teprve chvíli.",
  "Hotel3_9040_0030_ch2000": "Kde je Kevin?",
  "Hotel3_9040_0040_ch2100": "Taky se zpozdil.",
  "Hotel3_9041_0000": "",
  "Hotel3_9041_0010_ch2100": "Tak. Kam dneska jdeme?",
  "Hotel3_9041_0020_ch2000": "Do tý restaurace, o který jsem slyšel.\nTý fakt populární. Konečně se mi povedlo zarezervovat stůl.",
  "Hotel3_9041_0030_ch2100": "Vážně? To se těším!",
  "Hotel3_9041_0040_ch2000": "No, budeš si muset počkat.",
  "Hotel3_9041_0050_ch2000": "Kevin zas hodně mešká.\nDoufám, že nezapomněl.",
  "Hotel3_9041_0060_ch2100": "Tak to bude platit za večeři.",
  "Hotel3_9041_0070_ch2000": "To máš pravdu.",
  "Hotel3_9050_0000": "",
  "Hotel3_9050_0010_ch2100": "Slyšels, že Eric dostal povýšení?",
  "Hotel3_9050_0020_ch2100": "Ten hajzl? Co si ti manažeři\nkurva myslí?",
  "Hotel3_9050_0030_ch2100": "Jo, že? Je to poseroutka, co se flákne,\nzatímco my děláme veškerou práci.",
  "Hotel3_9050_0040_ch2100": "Dneska je fakt hnusný počasí.",
  "Hotel3_9050_0050_ch2100": "Jo, nepamatuju, kdy naposledy nebylo.",
  "Hotel3_9050_0060_ch2100": "Předpověď říkala, že bude jasno.",
  "Hotel3_9050_0070_ch2100": "Asi se spletli.",
  "Hotel3_9050_0080_ch2100": "Ach. To je na prd."
}