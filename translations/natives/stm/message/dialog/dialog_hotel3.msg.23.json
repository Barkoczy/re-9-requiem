  "Hotel3_c111s310_0000_ch1800": "<Sound Team ID>",
  "Hotel3_c111s310_0000": "",
  "Hotel3_c111s310_0010_ch1800": "Ahoj, zlatíčko.",
  "Hotel3_c111s310_0020_ch0200": "Ahoj, mami.",
  "Hotel3_c111s310_0030_ch1800": "Celý den jsi na tom přístroji.",
  "Hotel3_c111s310_0040_ch0200": "No, když pracuješ tak dlouho...",
  "Hotel3_c111s310_0050_ch1800": "Běž spát, jo?",
  "Hotel3_c111s310_0060_ch0200": "Už to skoro mám. Moment.",
  "Hotel3_c111s310_0070_ch1800": "Co s tebou jen budu dělat?",
  "Hotel3_c111s310_0080_ch0200": "To co vždycky.\nOtravovat mě, dokud nepůjdu spát.",
  "Hotel3_c111s310_0090_ch1800": "Teda, to ale padá.",
  "Hotel3_c111s310_0100_ch0200": "Mami, telefon.",
  "Hotel3_c111s310_0110_ch0200": "Mami.",
  "Hotel3_c111s310_0120_ch1800": "Máš ho hned vedle sebe.",
  "Hotel3_c111s310_0130_ch0200": "Fajn, dobře!",
  "Hotel3_c111s310_0140_ch0200": "Haló?",
  "Hotel3_c111s310_0150_ch5100": "Slečna Ashcroft?",
  "Hotel3_c111s310_0160_ch0200": "Ano.",
  "Hotel3_c111s310_0170_ch1800": "Kdo to byl?",
  "Hotel3_c111s310_0180_ch0200": "Nevím.",
  "Hotel3_c111s310_0190_ch0200": "Ptal se na slečnu Ashcroft\na pak mi zavěsil.",
  "Hotel3_c111s310_0200_ch0200": "Drzost.",
  "Hotel3_c111s310_0210_ch0200": "Co to...?",
  "Hotel3_c111s310_0220_ch1800": "Přicházejí.",
  "Hotel3_c111s310_0230_ch1800": "Grace, musíme jít.",
  "Hotel3_c111s310_0240_ch0200": "Kam?",
  "Hotel3_c111s310_0250_ch0200": "Mami, co se děje?",
  "Hotel3_c111s310_0260_ch1800": "Honem!",
  "Hotel3_c111s310_0270_ch0200": "Počkej, kdo přichází? Co je?",
  "Hotel3_c111s310_0290_ch1800": "Musíme být potichu.",
  "Hotel3_c111s310_0300_ch0200": "To je absurdní.",
  "Hotel3_c111s310_0310_ch1800": "Pojď!",
  "Hotel3_c111s310_0320_ch0200": "Řekni mi, co se děje.",
  "Hotel3_c111s310_0330_ch1800": "Teď na to není čas.",
  "Hotel3_1110_0000_ch1800": "<Sound Team ID>",
  "Hotel3_1110_0000": "",
  "Hotel3_1110_0010_ch1800": "Grace! Pospěš si!",
  "Hotel3_1110_0020_ch1800": "Nepřestávej!",
  "Hotel3_1300_0000_ch1800": "<Sound Team ID>",
  "Hotel3_1300_0000": "",
  "Hotel3_1300_0010_ch1800": "Drž se u mě.",
  "Hotel3_1300_0020_ch1800": "Grace! Pojď, nepřestávej.",
  "Hotel3_1360_0000": "",
  "Hotel3_1360_0010_ch0200": "Mami, počkej!",
  "Hotel3_1371_0000": "",
  "Hotel3_1371_0010_ch1800": "Grace, prosím, soustřeď se.",
  "Hotel3_1415_0000": "",
  "Hotel3_1415_0010_ch0200": "Už jdu!",
  "Hotel3_1420_0000": "",
  "Hotel3_1420_0010_ch1800": "Grace. Drž se u mě.",
  "Hotel3_c111s410_0000_ch1800": "<Sound Team ID>",
  "Hotel3_c111s410_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s410_0000_ch4210": "<Sound Team ID>",
  "Hotel3_c111s410_0000": "",
  "Hotel3_c111s410_0010_ch4210": "Haló?",
  "Hotel3_c111s410_0020_ch4210": "Kdo je tam?",
  "Hotel3_c111s410_0030_ch4210": "Ach!",
  "Hotel3_c111s410_0040_ch4210": "Moc se omlouvám za výpadek proudu.",
  "Hotel3_c111s410_0050_ch0200": "Ehm, co se stalo?",
  "Hotel3_c111s410_0060_ch4210": "Ach, to bude elektrický panel.",
  "Hotel3_c111s410_0070_ch4210": "Je čtyřicet let starý, takže\nstačí málo, aby vypadl.",
  "Hotel3_c111s410_0080_ch4210": "To ale není omluva a omlouvám\nse za nepříjemnosti.",
  "Hotel3_c111s410_0090_ch0200": "Ach ne, to je v pořádku.",
  "Hotel3_c111s410_0100_ch1800": "Jo, s tím si nedělejte hlavu.",
  "Hotel3_c111s410_0110_ch4210": "Brzy to opravím,",
  "Hotel3_c111s410_0120_ch4210": "jen musím najít svůj —",
  "Hotel3_c111s410_0130_ch0200": "Ježíši!",
  "Hotel3_c111s410_0145_ch0200": "Mami!",
  "Hotel3_c111s410_0150_ch0200": "Co to děláš, mami!?",
  "Hotel3_c111s410_0160_ch1800": "Ne, ne, ne! Grace! Ne.",
  "Hotel3_c111s410_0170_ch1800": "Grace, drž se u mě.",
  "Hotel3_c111s410_0180_ch0200": "Řekneš mi konečně, co se děje!?",
  "Hotel3_c111s410_0190_ch0200": "",
  "Hotel3_c111s410_0200_ch0200": "Mami, co to děláš!?",
  "Hotel3_c111s410_0210_ch1800": "Něco důležitého.",
  "Hotel3_c111s410_0220_ch0200": "Cos schovala za ten obraz?",
  "Hotel3_c111s410_0230_ch1800": "Vysvětlím ti to později.",
  "Hotel3_c111s410_0240_ch1800": "Musíme najít jinou cestu ven.",
  "Hotel3_1450_0000_ch1800": "<Sound Team ID>",
  "Hotel3_1450_0000": "",
  "Hotel3_1450_0010_ch1800": "Grace! Pojď!",
  "Hotel3_1460_0000": "",
  "Hotel3_1460_0010_ch1800": "Nepřestávej, Grace. Nepřestávej.",
  "Hotel3_1500_0000_ch1800": "<Sound Team ID>",
  "Hotel3_1500_0000": "",
  "Hotel3_1500_0010_ch1800": "Pojď, Grace!",
  "Hotel3_1500_0020_ch1800": "Pojď, pospěš!",
  "Hotel3_c111s500_0000_ch1800": "<Sound Team ID>",
  "Hotel3_c111s500_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s500_0000_ch4010": "<Sound Team ID>",
  "Hotel3_c111s500_0000": "",
  "Hotel3_c111s500_0010_ch1800": "Pojď dovnitř, Grace.",
  "Hotel3_c111s500_0020_ch0200": "Volám policii!",
  "Hotel3_c111s500_0030_ch1800": "Ne! Nevolej policii!",
  "Hotel3_c111s500_0035_ch0200": "Ne, ne, ne! Pšt!",
  "Hotel3_c111s500_0040_ch0200": "Haló?",
  "Hotel3_c111s500_0050_ch0200": "Ano, chci nahlásit vraždu...\nNe, vraždy!",
  "Hotel3_c111s500_0060_ch1800": "Grace!",
  "Hotel3_c111s500_0070_ch0200": "W-Wrenwood Hotel.",
  "Hotel3_c111s500_0080_ch0200": "Ano. Pospěšte si! Prosím.",
  "Hotel3_c111s500_0090_ch0200": "Policie je na cestě.",
  "Hotel3_c111s500_0095_ch0200": "Ježíši.",
  "Hotel3_c111s500_0100_ch0200": "Mami, já... Asi\nbudu zvracet.",
  "Hotel3_c111s500_0110_ch1800": "Grace?",
  "Hotel3_c111s500_0120_ch1800": "Grace, podívej se na mě.\nChyť mě za ruce.",
  "Hotel3_c111s500_0130_ch1800": "OK, podívej se na mě. Podívej se na mě.",
  "Hotel3_c111s500_0140_ch1800": "Nadechni se...a vydechni... Nadechni se a vydechni.",
  "Hotel3_c111s500_0150_ch1800": "Grace. Slibuju ti, že ti to všechno\njednou vysvětlím.",
  "Hotel3_c111s500_0160_ch1800": "Grace.",
  "Hotel3_c111s500_0170_ch1800": "Věz, že jsi má naděje.",
  "Hotel3_c111s500_0180_ch1800": "Nikdy na to nezapomeň.",
  "Hotel3_c111s500_0190_ch0200": "O čem to mluvíš?",
  "Hotel3_c111s500_0200_ch1800": "Jen...",
  "Hotel3_c111s500_0210_ch1800": "Miluju tě.",
  "Hotel3_c111s500_0220_ch0200": "Já tebe taky.",
  "Hotel3_c111s500_0230_ch1800": "Ano?",
  "Hotel3_c111s500_0240_ch0200": "Mami, bojím se!",
  "Hotel3_c111s500_0250_ch1800": "Ne, ne, ne. Musíme\nodtud najít cestu ven.",
  "Hotel3_c111s500_0260_ch0200": "A-Ale nemáme žádný naše věci.",
  "Hotel3_c111s500_0270_ch1800": "Pro ty se můžeme vrátit později, Grace.",
  "Hotel3_c111s500_0280_ch0200": "Necháp—",
  "Hotel3_c111s500_0290_ch4010": "Našel jsem vás.",
  "Hotel3_c111s500_0300_ch0200": "Ne... Ne!",
  "Hotel3_c111s500_0310_ch0200": "Mami! Mami, prosím!",
  "Hotel3_c111s500_0320_ch0200": "Ne...Mami!",
  "Hotel3_c111s500_0330_ch0200": "Ne, prosím, ne!",
