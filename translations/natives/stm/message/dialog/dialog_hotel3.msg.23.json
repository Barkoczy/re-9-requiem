  "Hotel3_c110s000_0090_ch1500": "Grace!",
  "Hotel3_c110s000_0100_ch1500": "Grace!",
  "Hotel3_c110s000_0110_ch1500": "Grace Ashcroft.",
  "Hotel3_c110s000_0120_ch0200": "Ehm, ano?",
  "Hotel3_c110s000_0130_ch1500": "Ke mně do kanceláře.",
  "Hotel3_c110s000_0140_ch0200": "Aha... Ehm...",
  "Hotel3_c110s000_0150_ch0200": "Už jdu!",
  "Hotel3_c110s000_0160_ch0200": "Do prdele.",
  "Hotel3_c110s000_0170_ch0200": "J-Jestli jde o tu zprávu,\no kterou jste mě včera žádal,",
  "Hotel3_c110s000_0180_ch0200": "bude hotová za tři —",
  "Hotel3_c110s000_0190_ch0200": "ne, ne, za dva dny, maximálně.",
  "Hotel3_c110s000_0200_ch1500": "To teď odlož.",
  "Hotel3_c110s000_0210_ch1500": "Našli jsme další tělo.",
  "Hotel3_c110s000_0220_ch1500": "Vykazuje stejnou patologii jako\nostatní případy, které vyšetřujeme.",
  "Hotel3_c110s000_0230_ch1500": "Potřebuju na to dobrou technickou analytičku.",
  "Hotel3_c110s000_0240_ch0200": "OK.",
  "Hotel3_c110s000_0250_ch1500": "Potřebuju, abys prozkoumala místo činu.",
  "Hotel3_c110s000_0260_ch1500": "Wrenwood Hotel.",
  "Hotel3_c110s000_0265_ch1500": "Podívej...",
  "Hotel3_c110s000_0270_ch1500": "Vím, že tam byla\nzavražděna tvoje matka...",
  "Hotel3_c110s000_0280_ch1500": "a vím, že to pro tebe bude těžké.",
  "Hotel3_c110s000_0290_ch1500": "Alyssa zemřela před osmi lety.",
  "Hotel3_c110s000_0300_ch1500": "Možná je čas čelit minulosti?",
  "Hotel3_c110s000_0310_ch1500": "Postavit se tomu strachu čelem.",
  "Hotel3_c110s000_0320_ch1500": "Grace...",
  "Hotel3_c110s000_0330_ch1500": "Nebudu tě do toho nutit,",
  "Hotel3_c110s000_0340_ch1500": "ale zvládneš to pro mě udělat?",
  "Hotel3_c110s000_0350_ch1500": "Prozkoumej místo činu a podej\nmi zprávu o svých zjištěních.",
  "Hotel3_c110s000_0360_ch1500": "To je zatím vše.",
  "Hotel3_c111s000_0000_ch2010": "<Sound Team ID>",
  "Hotel3_c111s000_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s000_0000": "",
  "Hotel3_c111s000_0010_ch0200": "Promiň.",
  "Hotel3_c111s000_0020_ch2010": "",
  "Hotel3_0010_0000": "",
  "Hotel3_0010_0010_ch0200": "Musím se dostat k hotelu.",
  "Hotel3_0020_0000": "",
  "Hotel3_0020_0010_ch0200": "Mělo by to být tady někde.",
  "Hotel3_c111s100_0000_ch0200": "<Sound Team ID>",
  "Hotel3_c111s100_0000_ch4030": "<Sound Team ID>",
  "Hotel3_c111s100_0000": "",
  "Hotel3_c111s100_0010_ch4030": "Hej, slečno?",
  "Hotel3_c111s100_0020_ch4030": "Hej, tamhle je uzavřená zóna.",
  "Hotel3_c111s100_0030_ch4030": "Tam nesmíte.",
  "Hotel3_c111s100_0040_ch0200": "A-Ach, aha, ehm...",
  "Hotel3_c111s100_0050_ch0200": "P-Proč?",
  "Hotel3_c111s100_0060_ch4030": "Je to aktivní místo činu.",
  "Hotel3_c111s100_0070_ch0200": "Aha! Jasně, promiňte. Ehm...",
  "Hotel3_c111s100_0080_ch0200": "Moment.",
  "Hotel3_c111s100_0090_ch4030": "Aha, vy jste od FBI?",
  "Hotel3_c111s100_0100_ch0200": "Ano.",
  "Hotel3_c111s100_0110_ch4030": "Vyšetřujete ty podivný\númrtí, co?",
  "Hotel3_c111s100_0120_ch0200": "Mhm.",
  "Hotel3_c111s100_0130_ch4030": "Tohle je už páté, ne?",
  "Hotel3_c111s100_0140_ch4030": "Slyšel jsem, že všichni mají stejný podivný modřiny.",
  "Hotel3_c111s100_0150_ch4030": "Takže si myslíte, že je to něco nakažlivýho,\nnebo terorismus, nebo...?",
  "Hotel3_c111s100_0160_ch4030": "Proč jinak by to\nvyšetřovala FBI, že?",
  "Hotel3_c111s100_0170_ch4030": "Hej, posloucháte mě?",
  "Hotel3_c111s100_0175_ch0200": "Aha, ehm. Uh...",
  "Hotel3_c111s100_0180_ch0200": "Odpovědi můžou být uvnitř.",
  "Hotel3_c111s100_0190_ch4030": "Jo. Jasně. Správně.",
  "Hotel3_c111s100_0200_ch4030": "Buďte tam opatrná.",
  "Hotel3_c111s100_0210_ch4030": "Celá budova je určená k demolici — prý ji\nkonečně celou srovnají se zemí.",
  "Hotel3_c111s100_0220_ch0200": "Jo. Díky.",
  "Hotel3_0211_0000": "",
  "Hotel3_0211_0010_ch0200": "Proč jsem sem vůbec šla?",
  "Hotel3_0220_0000": "",
  "Hotel3_0220_0010_ch0200": "",
  "Hotel3_0430_0000_ch0200": "<Sound Team ID>",
  "Hotel3_0430_0000": "",
  "Hotel3_0430_0010_ch0200": "",
  "Hotel3_0450_0000_ch0200": "<Sound Team ID>",
