{
  "ManLH_c312s101_0000_ch0100": "<Sound Team ID>",
  "ManLH_c312s101_0000_ch4155": "<Sound Team ID>",
  "ManLH_c312s101_0000": "",
  "ManLH_c312s101_0010_ch4155": "Pane Kennedy, vítejte.\r\nDr. Gideon vás již očekává.",
  "ManLH_c312s101_0020_ch0100": "Vtipný. Nepamatuju si, že bych dostal pozvánku.",
  "ManLH_c312s101_0030_ch4155": "Tak, čeká na vás.",
  "ManLH_c312s101_0040_ch0100": "To přece nemůžeme dopustit, že ne?",
  "ManLH_c312s101_0050_ch4155": "Pojďte za mnou, prosím.",
  "ManLH_c312s101_0060_ch0100": "Veďte cestu.",
  "ManLH_c312s101_0070_ch0100": "Tak jak dlouho pracujete pro,\r\nehm...Dr. Gideona?",
  "ManLH_c312s101_0080_ch4155": "Nedlouho. Teprve nedávno jsem se přidal k týmu.",
  "ManLH_0050_0000": "",
  "ManLH_0050_0010_ch4155": "Staráme se tu o poměrně hodně\r\ndlouhodobých pacientů.",
  "ManLH_0050_0020_ch4155": "Všichni podstupují experimentální terapie\r\nvyvinuté Dr. Gideonem.",
  "ManLH_0055_0000": "",
  "ManLH_0055_0010_ch0100": "Experimentální terapie?",
  "ManLH_0055_0020_ch4155": "Ano, je to všechno velmi pokrokové.",
  "ManLH_0055_0030_ch4155": "Zařízení udržuje nízký profil kvůli\r\ncitlivé povaze výzkumu.",
  "ManLH_0055_0040_ch0100": "Ó, to věřím.",
  "ManLH_c312s210_0000_ch4155": "<Sound Team ID>",
  "ManLH_c312s210_0000_ch0100": "<Sound Team ID>",
  "ManLH_c312s210_0000_ch4055": "<Sound Team ID>",
  "ManLH_c312s210_0000_ch9910": "<Sound Team ID>",
  "ManLH_c312s210_0000": "",
  "ManLH_c312s210_0010_ch4155": "Prosím, počkejte tady.",
  "ManLH_c312s210_0020_ch9910": "Kód šest! Kód šest! Veškerý personál,\r\nzahajte nouzové protokoly!",
  "ManLH_c312s210_0030_ch4155": "Pane Kennedy, musíme okamžitě odejít!",
  "ManLH_c312s210_0040_ch0100": "Co se děje?",
  "ManLH_c312s210_0050_ch4155": "Nevím, co se to děje.",
  "ManLH_c312s210_0060_ch4155": "Nějaká masová hysterie.\r\nNemocnice je v uzávěře.",
  "ManLH_c312s210_0070_ch4155": "Doktore?",
  "ManLH_c312s210_0080_ch4055": "Vy...řízni...",
  "ManLH_c312s210_0090_ch0100": "Myslím, že si vyžádám druhý názor.",
  "ManLH_0200_0000": "",
  "ManLH_0200_0010_ch0100": "Pěkný.",
  "ManLH_0481_0000": "",
  "ManLH_0481_0010_ch0100": "No, to šlo dobře.",
  "ManLH_0502_0000": "",
  "ManLH_0502_0010_ch0100": "Ten parchant to zase udělal.",
  "ManLH_0502_0020_ch0100": "Jak to vypadá u tebe?",
  "ManLH_0502_0030_ch0600": "Právě jsem se nabourala do sítě centra.",
  "ManLH_0502_0040_ch0100": "Dobře, dobře...\r\nMůžeš mi najít plán budovy?",
  "ManLH_0502_0050_ch0600": "Uvidím, co se dá dělat.",
  "ManLH_0502_0060_ch0100": "No, zatím se ho pokusím vystopovat.",
  "ManLH_0502_0070_ch0600": "Dávej mi vědět.",
  "ManLH_0502_0080_ch0100": "Jasně.",
  "ManLH_0900_0000_ch0200": "<Sound Team ID>",
  "ManLH_0900_0000": "",
  "ManLH_0900_0010_ch0200": "No tak, no tak, no tak,\r\nno tak, no tak!",
  "ManLH_c312s700_0000_ch0100": "<Sound Team ID>",
  "ManLH_c312s700_0000_ch0200": "<Sound Team ID>",
  "ManLH_c312s700_0000_ch5100": "<Sound Team ID>",
  "ManLH_c312s700_0000": "",
  "ManLH_c312s700_0010_ch0100": "Hej! Sem!",
  "ManLH_c312s700_0020_ch0200": "Dýchej... Dýchej...",
  "ManLH_c312s700_0030_ch0100": "Jsi v pořádku?",
  "ManLH_c312s700_0040_ch0200": "J-Jo. D-Díky...",
  "ManLH_c312s700_0050_ch0100": "Leon Kennedy, DSO.",
  "ManLH_c312s700_0060_ch0200": "DSO?",
  "ManLH_c312s700_0070_ch0200": "J-Jsem Grace, ehm... Ashcroft. Uh, FBI.",
  "ManLH_c312s700_0080_ch0100": "FBI?",
  "ManLH_c312s700_0090_ch0100": "Co tu děláš?",
  "ManLH_c312s700_0100_ch0200": "Někdo mě unesl.",
  "ManLH_c312s700_0110_ch0100": "Victor Gideon?",
  "ManLH_c312s700_0120_ch0200": "N-Nevím.",
  "ManLH_c312s700_0130_ch0100": "Tak, měli bychom jít.",
  "ManLH_c312s700_0140_ch0100": "Co od tebe Victor chce?",
  "ManLH_c312s700_0150_ch0200": "Co? Já, ehm, já—",
  "ManLH_c312s700_0160_ch0100": "Grace.",
  "ManLH_c312s700_0170_ch0200": "C-Co tím myslíš?",
  "ManLH_c312s700_0180_ch0100": "Sebral tě z nějakého důvodu.",
  "ManLH_c312s700_0190_ch0200": "Počkej! T-Ty jsi DSO.",
  "ManLH_c312s700_0200_ch0200": "To je ta, ehm, uh...\r\nprotibioteroristická agentura, ne?",
  "ManLH_c312s700_0210_ch0100": "Vezmi si tohle.",
  "ManLH_c312s700_0220_ch0200": "Jsi si jistý?",
  "ManLH_c312s700_0230_ch0100": "Mohla bys to potřebovat.",
  "ManLH_c312s700_0240_ch0100": "Teď běž.",
  "ManLH_c312s700_0250_ch0100": "Vypadni odsud.",
  "ManLH_c312s700_0260_ch5100": "Neuteče, to víš.",
  "ManLH_c312s700_0270_ch0100": "Dr. Gideon.",
  "ManLH_c312s700_0280_ch5100": "Jak milé se konečně setkat, Leone.",
  "ManLH_c312s700_0290_ch5100": "Co kdybychom si trochu popovídali?",
  "ManLH_c312s700_0300_ch5100": "Příliš pomalý.",
  "ManLH_c312s700_0310_ch5100": "Vidím, že i ty vykazuješ příznaky.",
  "ManLH_c312s700_0320_ch5100": "Prokletí Umbrella.",
  "ManLH_c312s700_0330_ch5100": "Pšš...",
