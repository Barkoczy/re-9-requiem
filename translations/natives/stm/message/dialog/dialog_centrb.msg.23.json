  "CentRB_c440s000_0000": "",
  "CentRB_c440s000_0010_ch0600": "Měl bys být blízko těch souřadnic.",
  "CentRB_c440s000_0020_ch0100": "Jo.",
  "CentRB_c440s000_0030_ch0100": "Vypadá to.",
  "CentRB_c440s000_0040_ch0100": "Tak se tu rozhlédnu.",
  "CentRB_0150_0000": "",
  "CentRB_0150_0010_ch0100": "To snad ne, že to ještě stojí.",
  "CentRB_c440s200_0000_ch9944": "<Sound Team ID>",
  "CentRB_c440s200_0000": "",
  "CentRB_c440s200_0010_ch9944": "Teď je to na tobě.",
  "CentRB_0210_0000_ch0100": "<Sound Team ID>",
  "CentRB_0210_0000": "",
  "CentRB_0210_0010_ch0100": "",
  "CentRB_c440s300_0000_ch0600": "<Sound Team ID>",
  "CentRB_c440s300_0000_ch0100": "<Sound Team ID>",
  "CentRB_c440s300_0000": "",
  "CentRB_c440s300_0010_ch0100": "Sherry, jsem v R.P.D.",
  "CentRB_c440s300_0020_ch0600": "Už je to dlouho, co jsi tam byl naposledy...",
  "CentRB_c440s300_0030_ch0100": "Jo.",
  "CentRB_c440s300_0040_ch0100": "Vypadá to, že si tu BSAA zřídila velitelství.",
  "CentRB_c440s300_0050_ch0600": "Opuštěné?",
  "CentRB_c440s300_0060_ch0100": "Nevím jistě.",
  "CentRB_c440s300_0065_dummy": "",
  "CentRB_c440s300_0070_ch0100": "Ten zkurvený chlap...",
  "CentRB_c440s300_0080_ch0100": "A Grace.",
  "CentRB_c440s300_0085_ch0100": "Kurva, je v nebezpečí.",
  "CentRB_c440s300_0090_ch0100": "Sherry, našel jsem Grace.",
  "CentRB_c440s300_0100_ch0600": "V R.P.D.?",
  "CentRB_c440s300_0110_ch0100": "Jo, přesně.",
  "CentRB_c440s300_0120_ch0100": "A někdo nás tu očekával.",
  "CentRB_c440s300_0130_ch0100": "Mám zaměřenou její polohu.",
  "CentRB_c440s300_0140_ch0100": "Mířím tam.",
  "CentRB_c440s300_0150_ch0600": "Rozumím.",
