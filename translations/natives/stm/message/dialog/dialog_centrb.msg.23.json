  "CentRB_c440s900_0000_ch0200": "<Sound Team ID>",
  "CentRB_c440s900_0000_ch8000": "<Sound Team ID>",
  "CentRB_c440s900_0000": "",
  "CentRB_c440s900_0010_ch8000": "Tajné vojenské jednotky z celého světa\r\npřijíždějí do Raccoon City s jediným cílem...",
  "CentRB_c440s900_0015_ch8000": "Najít Elpis.",
  "CentRB_c440s900_0020_ch0200": "C-Co je to Elpis?",
  "CentRB_c440s900_0030_ch8000": "Síla schopná narušit vojenskou\r\nrovnováhu celého světa.",
  "CentRB_c440s900_0040_ch8000": "Poslední virus vytvořený Spencerem.",
  "CentRB_c440s900_0050_ch8000": "Navržený k ovládání lidského vědomí.",
  "CentRB_c440s900_0060_ch0200": "Ovládání mysli?",
  "CentRB_c440s900_0070_ch8000": "Nemohli dopustit, aby byl ukraden.",
  "CentRB_c440s900_0080_ch8000": "Tak odpálili raketu, aby ho ukryli.",
  "CentRB_c440s900_0090_ch0200": "Ukrýt virus... Proč dělat něco tak extrémního?",
  "CentRB_c440s900_0100_ch8000": "Extrémního?",
  "CentRB_c440s900_0110_ch8000": "Opravdu?",
  "CentRB_c440s900_0120_ch8000": "Když se to prezident pokusil vyšetřit,\r\nnechali ho zavraždit.",
  "CentRB_c440s900_0130_ch8000": "A ty jsi klíč k získání Elpis.",
  "CentRB_c440s900_0140_ch0200": "Emily?",
  "CentRB_c440s900_0150_ch8000": "Svým způsobem, ale ne ta dívka, kterou jsi potkala.",
  "CentRB_c440s900_0160_ch8000": "Tolik pokusů.",
  "CentRB_c440s900_0170_ch8000": "Tolik selhání.",
  "CentRB_c440s900_0180_ch8000": "Takové plýtvání.",
  "CentRB_c440s900_0190_ch0200": "C-Co tím myslíš?",
  "CentRB_c440s900_0200_ch8000": "Kopie, vytvořené jako tvůj duplikát.",
  "CentRB_c440s900_0210_ch8000": "Všechny k ničemu.",
  "CentRB_c440s900_0220_ch8000": "Všechny vyřazené.",
  "CentRB_c440s900_0230_ch8000": "Každá z nich má svůj smutný příběh.",
  "CentRB_c442s100_0000_ch0100": "<Sound Team ID>",
  "CentRB_c442s100_0000_ch0600": "<Sound Team ID>",
  "CentRB_c442s100_0000_ch8000": "<Sound Team ID>",
  "CentRB_c442s100_0000_ch0200": "<Sound Team ID>",
  "CentRB_c442s100_0000": "",
  "CentRB_c442s100_0010_ch8000": "Nedokázali znovu vytvořit Spencerův klíč.",
  "CentRB_c442s100_0020_ch8000": "Ale teď máme originál.",
  "CentRB_c442s100_0030_ch8000": "Máme tebe.",
  "CentRB_c442s100_0040_ch8000": "Můžeš odemknout Elpis na ARK.",
  "CentRB_c442s100_0050_ch8000": "Tam zamíříme.",
  "CentRB_c442s100_0060_ch0200": "Takže, j-jak? J-Já...",
  "CentRB_c442s100_0070_ch0200": "Já jsem byla vyrobena?",
  "CentRB_c442s100_0080_ch8000": "Správně.",
  "CentRB_c442s100_0090_ch0200": "T-Takže je to opravdu celé moje vina?",
  "CentRB_c442s100_0100_ch8000": "Co přesně?",
  "CentRB_c442s100_0110_ch0200": "Ž-Že mámu z-zavraždili a...",
  "CentRB_c442s100_0120_ch0200": "Proboha, že se Emily p-proměnila\r\nv tu...tu věc.",
  "CentRB_c442s100_0130_ch8000": "Co se stalo, to se stalo.",
  "CentRB_c442s100_0140_ch8000": "Musíš se soustředit na budoucnost.",
  "CentRB_c442s100_0150_ch0200": "Byla to vůbec opravdu moje matka?",
  "CentRB_c442s100_0160_ch8000": "Je čas přijmout svůj osud.",
  "CentRB_c442s100_0170_ch0100": "Grace!",
  "CentRB_c442s100_0180_ch0200": "Mami...",
  "CentRB_c442s100_0190_ch0100": "Co to...?",
  "CentRB_c442s100_0200_ch8000": "Pane Kennedy.",
  "CentRB_c442s100_0210_ch8000": "Tušil jsem, že se ukážete.",
  "CentRB_c442s100_0220_ch8000": "Promiňte, ale nemám čas nazbyt.",
  "CentRB_c442s100_0230_ch8000": "Bavte se.",
  "CentRB_c442s100_0240_ch0100": "Pamatuju si tě.",
  "CentRB_c442s100_0250_ch0100": "Na tohle si taky vzpomínám.",
  "CentRB_c442s100_0260_ch0100": "Sherry.",
  "CentRB_c442s100_0270_ch0100": "Nebyl tu někde sirotčinec?",
  "CentRB_c442s100_0280_ch0600": "Ano, byl. Proč?",
  "CentRB_c442s100_0290_ch0100": "Trochu zapátrám.",
  "CentRB_c442s300_0000_ch0600": "<Sound Team ID>",
  "CentRB_c442s300_0000_ch0100": "<Sound Team ID>",
  "CentRB_c442s300_0000": "",
  "CentRB_c442s300_0010_ch0600": "Všechno v pořádku, Leone?",
  "CentRB_c442s300_0020_ch0100": "Jo.",
  "CentRB_c442s300_0025_ch0100": "Jsem v pohodě.",
  "CentRB_c442s300_0030_ch0600": "Tak proč ses ptal na ten sirotčinec?",
  "CentRB_c442s300_0040_ch0100": "Berou Grace na ARK.",
  "CentRB_c442s300_0050_ch0100": "Ten sirotčinec je vchod.",
  "CentRB_0740_0000": "",
  "CentRB_0740_0010_ch0600": "Právě jsem ti poslala souřadnice.",
  "CentRB_0750_0000_ch0100": "<Sound Team ID>",
  "CentRB_0750_0000": "",
  "CentRB_0750_0010_ch0100": "",
  "CentRB_0755_0000_ch0100": "<Sound Team ID>",
  "CentRB_0755_0000": "",
  "CentRB_0755_0010_ch0100": "",
  "CentRB_0760_0000_ch0100": "<Sound Team ID>",
  "CentRB_0760_0000": "",
  "CentRB_0760_0010_ch0100": "",
  "CentRB_0801_0000": "",
  "CentRB_0801_0010_ch0100": "Dopřejte mi kurva chvilku klidu!",
  "CentRB_0820_0000_ch0100": "<Sound Team ID>",
  "CentRB_0820_0000": "",
  "CentRB_0820_0010_ch0100": "",
  "CentRB_0851_0000": "",
  "CentRB_0851_0010_ch0100": "Nemám čas se s tímhle zdržovat.",
  "CentRB_1110_0000": "",
  "CentRB_1110_0010_ch0600": "Co je to ARK?",
  "CentRB_1110_0020_ch0100": "Nevím přesně, ale zřejmě\r\nje to důležité místo.",
  "CentRB_1150_0000": "",
  "CentRB_1150_0010_ch0100": "Vůbec se to tu nezměnilo...",
  "CentRB_c442s500_0000_ch0100": "<Sound Team ID>",
  "CentRB_c442s500_0000_ch9929": "<Sound Team ID>",
  "CentRB_c442s500_0000": "",
  "CentRB_c442s500_0010_ch9929": "\"Zlikvidovat\"? To je sakra moje dcera!",
  "CentRB_c442s500_0020_ch9929": "Ty jsi policajt.",
  "CentRB_c442s500_0030_ch9929": "Měl bys něco vědět—\r\njak se to sakra stalo!?",
  "CentRB_c442s500_0040": "\"Umbrella Corporation – Předpis\r\nRobert Kendo\"",
  "CentRB_c442s500_0050_ch9929": "Ty zkurvený věci venku...\r\nPodívej, co nám udělaly.",
  "CentRB_c442s500_0060_ch0100": "To je mi moc líto.",
  "CentRB_c442s500_0070_ch0100": "Už nikdy víc.",
  "CentRB_c442s600_0000_ch0100": "<Sound Team ID>",
  "CentRB_c442s600_0000": "",
  "CentRB_c442s600_0010_ch0100": "Do prdele.",
  "CentRB_c442s600_0020_ch0100": "Nemohl jsem je zachránit...",
  "CentRB_c442s600_0030_ch0100": "Ale můžu zastavit takový zmrdy jako ty.",
  "CentRB_5000_0000": "",
  "CentRB_5000_0010_ch0100": "",
  "CentRB_5000_0020_ch0100": "Chcípni už konečně, ty zkurvenej svině.",
  "CentRB_5010_0000": "",
  "CentRB_5010_0010_ch0100": "",
  "CentRB_5010_0020_ch0100": "Kdyby nebylo vás, hajzlů...",
  "CentRB_5050_0000": "",
  "CentRB_5050_0010_ch0100": "Ještě...ne...",
  "CentRB_1200_0000": "",
  "CentRB_1200_0010_ch0100": "Zastavím tě, kolikrát bude třeba.",
  "CentRB_1230_0000": "",
  "CentRB_1230_0010_ch0100": "Zvládnuto.",
  "CentRB_1250_0000": "",
  "CentRB_1250_0010_ch0100": "Jsem u sirotčince, Sherry.\r\nMoc toho z něj nezbylo.",
  "CentRB_1250_0020_ch0100": "Jdu pod zem hledat Grace.",
  "CentRB_1250_0030_ch0600": "Rozumím."
}