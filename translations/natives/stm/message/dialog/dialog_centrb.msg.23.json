  "CentRB_c440s301_0050_ch0600": "Opuštěné?",
  "CentRB_c440s301_0060_ch0100": "Nevím jistě.",
  "CentRB_c440s301_0065_dummy": "",
  "CentRB_c440s301_0070_ch0100": "Ten zkurvený chlap...",
  "CentRB_c440s301_0080_ch0100": "A Grace.",
  "CentRB_c440s301_0085_ch0100": "Kurva, je v nebezpečí.",
  "CentRB_c440s301_0090_ch0100": "Sherry, našel jsem Grace.",
  "CentRB_c440s301_0100_ch0600": "V R.P.D.?",
  "CentRB_c440s301_0110_ch0100": "Jo, přesně.",
